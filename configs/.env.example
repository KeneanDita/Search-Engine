# ─────────────────────────────────────────────────────────────────
# Search Engine — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────

# ── Free API Keys ─────────────────────────────────────────────────
# Tavily Search API (https://tavily.com) — 1000 req/month free
TAVILY_API_KEY=

# Exa (formerly Metaphor) neural search (https://exa.ai) — free tier
EXA_API_KEY=

# Serper.dev SERP API (https://serper.dev) — 2500 queries free
SERPER_API_KEY=

# NewsAPI (https://newsapi.org) — 100 req/day developer free
NEWSAPI_KEY=

# GitHub Personal Access Token (https://github.com/settings/tokens)
# Unauthenticated: 60 req/hr | Authenticated: 5000 req/hr
GITHUB_TOKEN=

# StackExchange API key (optional, increases rate limit)
STACKEXCHANGE_KEY=

# Unsplash API (https://unsplash.com/developers) — 50 req/hr free
UNSPLASH_ACCESS_KEY=

# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=searchengine
POSTGRES_PASSWORD=searchengine
POSTGRES_DB=searchengine

# ── Services ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
OPENSEARCH_URL=http://opensearch:9200
NLP_URL=http://python-nlp:8001

# ── NLP Config ────────────────────────────────────────────────────
# Embedding model (HuggingFace sentence-transformers)
# Options: all-MiniLM-L6-v2 (fast, 384d) | all-mpnet-base-v2 (better, 768d)
EMBEDDING_MODEL=all-MiniLM-L6-v2
NLP_BATCH_SIZE=16
MAX_TEXT_CHARS=8000

# ── Search API ────────────────────────────────────────────────────
RATE_RPS=20
RATE_BURST=50

# ── Features ──────────────────────────────────────────────────────
# Set to "true" to enable JavaScript-rendered page crawling (slower)
USE_PLAYWRIGHT=false

# ── Observability ─────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
